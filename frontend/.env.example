# =============================================================================
# Frontend env — copy to .env and fill values. Never commit .env.
# =============================================================================

REACT_APP_BACKEND_URL=http://localhost:8000

# --- Supabase (required) — Project Settings → API (anon / publishable key only) ---
REACT_APP_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
REACT_APP_SUPABASE_ANON_KEY=your_anon_key

# Email OTP uses Supabase Auth (configure Resend SMTP in Supabase dashboard).
# true = password-reset console helper only; email OTP always goes through Supabase email.
REACT_APP_CONSOLE_OTP=false

# DO NOT put Twilio / Emergent / Sarvam / Resend keys here.
