# =============================================================================
# Backend env — copy to .env and fill values. Never commit .env.
# =============================================================================

# --- Supabase (required) — Project Settings → API ---
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Dev helpers (password-reset link in console). Email OTP does not use this.
CONSOLE_OTP=false

# --- AI (voice recipes / dish images) ---
EMERGENT_LLM_KEY=your_emergent_universal_key
SARVAM_API_KEY=your_sarvam_api_key

# --- Invite emails (Resend) — also configure Resend as Supabase SMTP for Email OTP ---
# RESEND_API_KEY=re_xxxxxxxx
# RESEND_SENDER=Mamascript <noreply@yourdomain.com>
# RESEND_REPLY_TO=
# APP_URL=https://your-frontend.vercel.app

# --- CORS (production) ---
# CORS_ORIGINS=https://your-frontend.vercel.app
