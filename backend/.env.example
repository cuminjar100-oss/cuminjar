# =============================================================================
# Backend env — copy to .env and fill values. Never commit .env.
# =============================================================================

# --- Runtime (Render / deploy) ---
# Also pinned in runtime.txt. Set the same value in the Render dashboard
# Environment tab if the service has no Python version dropdown.
PYTHON_VERSION=3.12.10

# --- Supabase (required) — Project Settings → API ---
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# --- WhatsApp OTP ---
# Twilio Account SID + Auth Token go in the SUPABASE DASHBOARD only
# (Authentication → Providers → Phone → Twilio), NOT in this file.
# Set false once WhatsApp OTP is live; true = OTP printed in browser console (dev).
CONSOLE_OTP=false

# --- AI (required for voice recipes / dish images) — keep on backend only ---
EMERGENT_LLM_KEY=your_emergent_universal_key
SARVAM_API_KEY=your_sarvam_api_key

# --- Invite emails (optional but recommended) ---
# RESEND_API_KEY=re_xxxxxxxx
# RESEND_SENDER=Mamascript <noreply@yourdomain.com>
# RESEND_REPLY_TO=
# APP_URL=https://your-frontend.vercel.app

# --- CORS (production) ---
# CORS_ORIGINS=https://your-frontend.vercel.app
